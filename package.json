{
  "name": "fqreports",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker app for FlexiQuiz Moodle exports and multi-quiz reports",
  "type": "module",
  "scripts": {
    "start": "wrangler dev --local --port 4317",
    "dev": "wrangler dev --local --port 4317",
    "legacy:start": "node server.js",
    "cf:bootstrap": "node scripts/bootstrap-cloudflare.mjs",
    "deploy": "npm run cf:bootstrap && wrangler deploy",
    "types": "wrangler types src/worker-configuration.d.ts",
    "check": "npm run types && tsc --noEmit && wrangler deploy --dry-run",
    "test": "python3 -m unittest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.9.2",
    "wrangler": "^4.40.2"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
